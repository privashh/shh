{
  "name": "shh",
  "private": true,
  "version": "0.1.0",
  "description": "shh — a Base-based Privacy L3 on the OP Stack with shielded UTXO and compliant Privacy Pools",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "circuits:compile": "pnpm --filter @shh/circuits compile",
    "circuits:setup": "pnpm --filter @shh/circuits setup",
    "circuits:test": "pnpm --filter @shh/circuits test",
    "contracts:build": "pnpm --filter @shh/contracts build",
    "contracts:test": "pnpm --filter @shh/contracts test",
    "sdk:build": "pnpm --filter @shh/sdk build",
    "setup": "pnpm circuits:compile && pnpm circuits:setup && pnpm --filter @shh/sdk build && pnpm --filter @shh/contracts build",
    "dev": "node scripts/dev.mjs",
    "deploy:local": "pnpm --filter @shh/contracts deploy:local",
    "copy:artifacts": "node scripts/copy-artifacts.mjs",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "format": "prettier --write \"**/*.{ts,js,json,md,sol}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-solidity": "^1.4.1",
    "typescript": "5.4.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.4.5"
    }
  }
}
