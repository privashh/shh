# shh OP Stack L3 — copy to .env

# Settlement layer = Base Sepolia. Use a DEDICATED execution RPC (the public endpoint is
# rate-limited and op-node polls it heavily).
L1_RPC=https://sepolia.base.org
L1_CHAIN_ID=84532

# Base Sepolia BEACON / consensus-layer RPC. REQUIRED: op-node refuses to start once Ecotone
# is active (it is, from genesis) without a beacon — even though batches use calldata here.
L1_BEACON=

# shh L3 chain id
L2_CHAIN_ID=42069

# Keys — must be FUNDED on Base Sepolia:
#   ADMIN     deploys the OP Stack L1 contracts (op-deployer apply)
#   SEQUENCER signs L2 blocks (no L1 funds needed)
#   BATCHER   posts batches to L1   (needs ETH)
#   PROPOSER  posts output roots to the DisputeGameFactory (needs ETH + bond)
GS_ADMIN_PRIVATE_KEY=
GS_SEQUENCER_PRIVATE_KEY=
GS_BATCHER_PRIVATE_KEY=
GS_PROPOSER_PRIVATE_KEY=

# Filled in by scripts/generate from the op-deployer output
DGF_ADDRESS=
OP_GAME_TYPE=1

# Chain profile: full-privacy | open-pool
SHH_PROFILE=open-pool
