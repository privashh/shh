# shh OP Stack L3 — copy to .env

# Settlement layer = Base Sepolia. Use a DEDICATED execution RPC (the public endpoint is
# rate-limited and op-node polls it heavily).
L1_RPC=https://sepolia.base.org
L1_CHAIN_ID=84532

# Base is an L2 with NO beacon/blob API, so op-node runs without one (see docker-compose.yml:
# --l1.beacon.ignore + slot-duration-override, with calldata DA). No beacon RPC needed.
# L1_SLOT_SECONDS = the L1 block time op-node assumes (Base = 2s).
L1_SLOT_SECONDS=2

# shh L3 chain id
L2_CHAIN_ID=42069

# Keys — must be FUNDED on Base Sepolia:
#   ADMIN     deploys the OP Stack L1 contracts (op-deployer apply)
#   SEQUENCER signs L2 blocks (no L1 funds needed)
#   BATCHER   posts batches to L1   (needs ETH)
#   PROPOSER  posts output roots to the DisputeGameFactory (needs ETH + bond)
GS_ADMIN_PRIVATE_KEY=
GS_SEQUENCER_PRIVATE_KEY=
GS_BATCHER_PRIVATE_KEY=
GS_PROPOSER_PRIVATE_KEY=

# Filled in by scripts/generate from the op-deployer output
DGF_ADDRESS=
OP_GAME_TYPE=1

# --- OP Stack image tags (pin a COORDINATED release set; bump them together) ---
# Latest at time of writing. op-deployer's version dictates the op-contracts (protocol)
# version, which the node images must support — if boot fails on a fork/version mismatch,
# align these per the OP Stack release notes rather than mixing arbitrary tags.
OP_DEPLOYER_TAG=v0.6.0
OP_GETH_TAG=v1.101702.2
OP_NODE_TAG=v1.19.0
OP_BATCHER_TAG=v1.16.9
OP_PROPOSER_TAG=v1.16.3

# Chain profile: full-privacy | open-pool
SHH_PROFILE=open-pool

# Public RPC endpoint (rpc-proxy / Caddy). Set to the subdomain you point at this host with a
# DNS A record; Caddy provisions a Let's Encrypt cert for it. Ports 80/443 must be open.
RPC_DOMAIN=rpc.example.com
