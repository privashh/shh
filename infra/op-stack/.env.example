# shh OP Stack devnet — copy to .env

# Settlement layer (Base). Local default forks Base Sepolia; set to a live RPC to target real Base.
L1_RPC=https://sepolia.base.org
L1_CHAIN_ID=84532

# shh L3 chain id
L2_CHAIN_ID=42069

# Keys (local dev only — replace before any testnet/mainnet use)
GS_ADMIN_PRIVATE_KEY=
GS_SEQUENCER_PRIVATE_KEY=
GS_BATCHER_PRIVATE_KEY=
GS_PROPOSER_PRIVATE_KEY=

# Filled in by scripts/generate from the op-deployer output
DGF_ADDRESS=
OP_GAME_TYPE=1

# Chain profile: full-privacy | open-pool
SHH_PROFILE=open-pool
