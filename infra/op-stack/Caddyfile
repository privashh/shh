# Public TLS front for the shh L3 RPC. Caddy obtains/renews a Let's Encrypt cert for
# $RPC_DOMAIN automatically (requires ports 80/443 reachable from the internet and a DNS
# A record for $RPC_DOMAIN pointing at this host).
#
# It reverse-proxies to op-geth's PUBLIC-SAFE HTTP port (web3,eth,net only — no miner/debug/
# engine; see docker-compose.yml). CORS is opened so browser wallets can call the RPC directly.
{$RPC_DOMAIN} {
	encode gzip

	# Browser CORS: allow any origin to POST JSON-RPC and read the response.
	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "POST, OPTIONS"
		Access-Control-Allow-Headers "Content-Type"
	}
	# Answer CORS preflight without hitting the backend.
	@preflight method OPTIONS
	respond @preflight 204

	reverse_proxy op-geth:9545
}

# explorer.shh.gg — serves the Blockscout backend's REST API + Phoenix socket only. The public UI
# is the custom zine explorer at shh.gg/explorer, so any non-API request here redirects there.
explorer.shh.gg {
	encode gzip
	@backend path /api/* /socket/* /sitemap.xml /auth/* /metrics /public-metrics/*
	reverse_proxy @backend backend:4000
	@notapi not path /api/* /socket/* /sitemap.xml /auth/* /metrics /public-metrics/*
	redir @notapi https://shh.gg/explorer 302
}
