# shh SVM devnet — copy to .env and adjust.

# anzaxyz/agave image tag (the SVM node). Pin and bump deliberately.
AGAVE_TAG=v3.1.14

# Where the settler posts anchor memos. Devnet by default; any Solana RPC works.
SETTLE_L1_RPC=https://api.devnet.solana.com

# Seconds between anchors. Devnet airdrops are rate-limited; keep this modest.
ANCHOR_INTERVAL_SECONDS=300

# L1 program id of the deployed bridge (packages/svm-bridge). Only needed for the optional
# deposit relayer: docker compose --profile bridge up -d
BRIDGE_PROGRAM_ID=
