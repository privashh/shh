# shh explorer (Blockscout) — copy to .env

# L3 op-geth endpoints (host.docker.internal reaches the op-stack compose on the host)
L2_RPC_HTTP=http://host.docker.internal:9545
L2_RPC_WS=ws://host.docker.internal:9546
L2_CHAIN_ID=42069
COIN=ETH

# Postgres
DB_USER=blockscout
DB_PASSWORD=blockscout
DB_NAME=blockscout

# Generate a real one: `openssl rand -base64 48`
SECRET_KEY_BASE=

# Public host the frontend calls the API on
EXPLORER_HOST=localhost
