# shh explorer (Blockscout) — copy to .env

# L3 op-geth endpoints. The explorer joins the op-stack network (shh-devnet_default), so it
# reaches op-geth by service name.
L2_RPC_HTTP=http://op-geth:9545
L2_RPC_WS=ws://op-geth:8546
L2_CHAIN_ID=55666
COIN=ETH

# Postgres
DB_USER=blockscout
DB_PASSWORD=blockscout
DB_NAME=blockscout

# Generate a real one: `openssl rand -base64 48`
SECRET_KEY_BASE=

# Public host the frontend calls the API on (fronted by the Caddy rpc-proxy over TLS).
EXPLORER_DOMAIN=explorer.shh.gg
EXPLORER_PROTOCOL=https
EXPLORER_WS=wss
