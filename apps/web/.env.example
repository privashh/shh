# shh wallet backend — copy to .env.local

SHH_NETWORK=localhost
SHH_CHAIN_ID=31337
SHH_RPC_URL=http://127.0.0.1:8545

# Optional explicit overrides (otherwise read from packages/contracts/deployments/<network>.json)
# PRIVACY_POOL_ADDRESS=
# SHIELDED_POOL_ADDRESS=
# ASP_ADDRESS=

# Relayer (required only for POST /api/relayer/withdraw)
RELAYER_PRIVATE_KEY=
RELAYER_ADDRESS=
RELAYER_FEE_BPS=50
