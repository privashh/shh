# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
out/
.next/
artifacts/
cache/
typechain-types/
coverage/
coverage.json

# Web app generated artifacts (copied from circuits at dev time)
apps/web/public/circuits/*.wasm
apps/web/public/circuits/*.zkey
apps/web/public/vendor/

# Circuits — compiled artifacts & trusted setup
packages/circuits/build/
packages/circuits/ptau/*.ptau
packages/circuits/keys/*.zkey
packages/circuits/keys/*.wasm
!packages/circuits/keys/.gitkeep

# Local deployment artifacts (testnet/mainnet records are kept)
packages/contracts/deployments/hardhat.json
packages/contracts/deployments/localhost.json

# Env / secrets
.env
.env.*
!.env.example

# OP Stack runtime state (generated by generate.sh / docker; configs holds the jwt secret +
# a multi-MB genesis, .deployer holds op-deployer state — never commit these)
infra/op-stack/.devnet/
infra/op-stack/data/
infra/op-stack/configs/
infra/op-stack/.deployer/
infra/explorer/data/

# Logs & OS
*.log
.DS_Store
Thumbs.db
