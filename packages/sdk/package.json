{
  "name": "@privashh/sdk",
  "version": "0.1.0",
  "description": "shh client SDK: notes, Poseidon Merkle tree, witness + Groth16 proof generation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privashh/shh.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/privashh/shh#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "node --test \"test/**/*.test.js\""
  },
  "dependencies": {
    "ethers": "^6.13.4",
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
